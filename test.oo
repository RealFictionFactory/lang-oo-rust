// 1. Test zwykłego inputu (zwraca String)
var name = input("Podaj swoje imię: ")
print("Witaj, ", name, "!")

// 2. Test pobierania i konwersji na Number w jednej linii
var age = input("Podaj swój wiek: ").asNumber()
print("Za rok będziesz miał ", age + 1, " lat.")

// 3. Test pobierania i konwersji na Decimal
let pi = input("Podaj wartość PI (np. 3.14): ").asDecimal()
let r = input("Podaj promień koła: ").asNumber()
print("Pole koła wynosi: ", pi * r * r)

// 4. Test konwersji na Boolean
let is_admin_str = input("Czy jesteś adminem? (true/false): ")
let is_admin = is_admin_str.asBoolean()
if is_admin {
    print("Witaj, Administratorze!")
} else {
    print("Brak uprawnień administratora.")
}

// 5. Test metod String i ich łańcuchowania (chaining)
var shout = input("Napisz coś cicho: ").upper()
print("KRZYCZĘ: ", shout)
print("Twoje zawołanie ma długość: ", shout.length())

// 6. Test metod na tablicach
var nums = [10, 20, 30]
print("Początkowa długość tablicy: ", nums.length())
nums.push(40)
print("Nowa długość tablicy po dodaniu 40: ", nums.length())
print("Cała tablica: ", nums)
